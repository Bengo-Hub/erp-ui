# Example environment configuration for the ERP-UI (HR + internal operations).
# Copy to `.env` (or `.env.local`) and adjust per environment.
# Do NOT put secrets in this file — it is committed to version control.

# Realtime / websocket endpoint

# ---------------------------------------------------------------------------
# Backend API (ERP service)
# ---------------------------------------------------------------------------
# Base URL of the ERP backend (without the /api/v1 suffix). Defaults to
# http://localhost:8000 in dev. See src/main.js getApiBaseUrl().
# VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# SSO / Authentication (BengoBox auth-api)
# ---------------------------------------------------------------------------
# Delegated login via the platform SSO (OIDC Authorization Code + PKCE).
# See src/services/auth/ssoService.js and shared-docs/sso-integration-guide.md.

# Toggle SSO on. When false the legacy DRF /auth/security/login/ flow is used.
VITE_SSO_ENABLED=false

# SSO / auth-api base URL (no trailing slash). VITE_SSO_URL is preferred;
# VITE_AUTH_API_URL is kept as a legacy alias. VITE_AUTH_URL is used for the
# public tenant/outlet/branding endpoints (same auth-api host).
VITE_SSO_URL=http://localhost:8080
VITE_AUTH_URL=http://localhost:8080
# VITE_AUTH_API_URL=http://localhost:8080

# OAuth client id registered for this app in auth-api.
VITE_SSO_CLIENT_ID=erp-ui

# ---------------------------------------------------------------------------
# Subscriptions API (BengoBox subscriptions-api)
# ---------------------------------------------------------------------------
# Used by src/composables/useSubscription.js to fetch the tenant subscription
# (GET /api/v1/tenants/{tenant_id}/subscription). Fail-open; never blocks the UI.
VITE_SUBSCRIPTIONS_API_URL=http://localhost:8088

# ---------------------------------------------------------------------------
# External microservice frontends
# ---------------------------------------------------------------------------
# Other business domains have been decomposed into their own microservices,
# each with its own frontend. The ERP-UI navigation links out to these apps
# (opened in a new browser tab). Override the localhost defaults below to point
# at the deployed URLs for each environment. See src/config/externalServices.js.

# Finance / Treasury
# VITE_TREASURY_UI_URL=http://localhost:3001
# CRM / MarketFlow
# VITE_MARKETFLOW_UI_URL=http://localhost:3002
# Inventory (also serves Products, Procurement, Manufacturing, Assets)
# VITE_INVENTORY_UI_URL=http://localhost:3003
# Point of Sale
# VITE_POS_UI_URL=http://localhost:3004
# Ordering (online orders + storefront/shop)
# VITE_ORDERING_UI_URL=http://localhost:3005
# Notifications
# VITE_NOTIFICATIONS_UI_URL=http://localhost:3006
# Projects
# VITE_PROJECTS_UI_URL=http://localhost:3007
# Billing / Subscriptions
# VITE_SUBSCRIPTIONS_UI_URL=http://localhost:3008
# Auth
# VITE_AUTH_UI_URL=http://localhost:3009
VITE_WEBSOCKET_URL=wss://erpapi.masterspace.co.ke/ws/payroll/
