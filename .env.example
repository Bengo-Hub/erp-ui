# Example environment configuration for the ERP-UI (HR + internal operations).
# Copy to `.env` (or `.env.local`) and adjust per environment.
# Do NOT put secrets in this file — it is committed to version control.

# Realtime / websocket endpoint
VITE_WEBSOCKET_URL=ws://localhost:8000/ws/pos/

# ---------------------------------------------------------------------------
# External microservice frontends
# ---------------------------------------------------------------------------
# Other business domains have been decomposed into their own microservices,
# each with its own frontend. The ERP-UI navigation links out to these apps
# (opened in a new browser tab). Override the localhost defaults below to point
# at the deployed URLs for each environment. See src/config/externalServices.js.

# Finance / Treasury
# VITE_TREASURY_UI_URL=http://localhost:3001
# CRM / MarketFlow
# VITE_MARKETFLOW_UI_URL=http://localhost:3002
# Inventory (also serves Products, Procurement, Manufacturing, Assets)
# VITE_INVENTORY_UI_URL=http://localhost:3003
# Point of Sale
# VITE_POS_UI_URL=http://localhost:3004
# Ordering (online orders + storefront/shop)
# VITE_ORDERING_UI_URL=http://localhost:3005
# Notifications
# VITE_NOTIFICATIONS_UI_URL=http://localhost:3006
# Projects
# VITE_PROJECTS_UI_URL=http://localhost:3007
# Billing / Subscriptions
# VITE_SUBSCRIPTIONS_UI_URL=http://localhost:3008
# Auth
# VITE_AUTH_UI_URL=http://localhost:3009
