# ERP-UI (Next.js) environment variables.
# Vite VITE_* vars are mapped to NEXT_PUBLIC_* (build-time, see docs/integrations.md §9).
# Copy to .env.local for local development. NEVER commit real secrets.

# erp-api base (no /api/v1 suffix — the ApiClient appends paths).
# Leave UNSET in multi-tenant prod: the browser derives erpapi.<domain> from the UI host
# (erp.<domain>) and falls back to erpapi.codevertexitsolutions.com. Set only for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000

# auth-api / SSO base (token, /auth/me, branding by-slug, outlets)
NEXT_PUBLIC_SSO_URL=https://sso.codevertexitsolutions.com
# Optional alias used by some helpers for public branding/outlet endpoints
NEXT_PUBLIC_AUTH_API_URL=https://sso.codevertexitsolutions.com
# OAuth client id registered with auth-api
NEXT_PUBLIC_SSO_CLIENT_ID=erp-ui

# subscriptions-api base (plan/feature/limit gating)
NEXT_PUBLIC_SUBSCRIPTIONS_API_URL=https://pricingapi.codevertexitsolutions.com

# realtime websocket base (payroll progress — used in later sprints)
NEXT_PUBLIC_WEBSOCKET_URL=wss://erpapi.masterspace.co.ke/ws/payroll/

# External service UIs (opened in a new tab from the sidebar)
NEXT_PUBLIC_TREASURY_UI_URL=https://books.codevertexitsolutions.com
NEXT_PUBLIC_MARKETFLOW_UI_URL=https://marketflow.codevertexitsolutions.com
NEXT_PUBLIC_INVENTORY_UI_URL=https://inventory.codevertexitsolutions.com
NEXT_PUBLIC_POS_UI_URL=https://pos.codevertexitsolutions.com
NEXT_PUBLIC_ORDERING_UI_URL=https://ordersapp.codevertexitsolutions.com
NEXT_PUBLIC_NOTIFICATIONS_UI_URL=https://notifications.codevertexitsolutions.com
NEXT_PUBLIC_PROJECTS_UI_URL=https://projects.codevertexitsolutions.com
NEXT_PUBLIC_SUBSCRIPTIONS_UI_URL=https://pricing.codevertexitsolutions.com
NEXT_PUBLIC_AUTH_UI_URL=https://accounts.codevertexitsolutions.com
